# ============================================================
# AiKanAja Backend (.env) — copy file ini ke `.env` lalu isi nilai nyata
# Bun auto-load file ini. Jangan commit `.env` (sudah di .gitignore).
# ============================================================

# ----- Server -----
PORT=3000
NODE_ENV=development

# ----- Database (Prisma + SQLite) -----
# Path relatif terhadap folder apps/api
DATABASE_URL="file:../data/dev.db"

# ----- Auth / JWT -----
# Ganti dengan string acak panjang. Dipakai untuk sign cookie login.
JWT_SECRET="ganti-dengan-string-acak-panjang-min-32-karakter"

# ----- CORS -----
# Origin frontend yang diizinkan. Bisa lebih dari 1, pisahkan dengan koma.
# Di dev pakai Vite proxy, ini untuk jaga-jaga / kalau ada 2 frontend port.
# Contoh: "http://localhost:5173,http://localhost:5174"
CORS_ORIGIN="http://localhost:5173"

# ----- Google OAuth 2.0 (dari Google Cloud Console) -----
# Tipe: Web application. Authorized redirect URI = http://localhost:3000/auth/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/callback"

# ----- Frontend URL (redirect tujuan setelah OAuth callback) -----
FRONTEND_URL="http://localhost:5173"

# ----- AI Provider Keys (round-robin) -----
# Minimal 1 terisi. Kalau kosong semua, generate gagal kecuali user pakai API key sendiri.
GROQ_AI_API_KEY1=""
GROQ_AI_API_KEY2=""
GROQ_AI_API_KEY3=""
GROQ_AI_API_KEY4=""
GEMINI_API_KEY1=""
GEMINI_API_KEY2=""
GEMINI_API_KEY3=""

# ----- Cloudinary (upload avatar, opsional) -----
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
