generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  avatar    String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ERD Generator relations
  erdProjects  ErdProject[]
  erdShares    ErdShare[]
  usage        Usage[]
  payments     Payment[]
  activities   Activity[]

  // PRD Generator relations
  prdProjects  PrdProject[]
  prdShares    PrdShare[]
}
