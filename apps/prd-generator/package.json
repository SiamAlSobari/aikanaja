		"@tiptap/starter-kit": "^2.11.5",
		"daisyui": "^5.6.18",
		"diff": "^7.0.0",
		"docx": "^9.2.0",
		"file-saver": "^2.0.5",
		"lucide-svelte": "^1.0.1",
