    {
      "id": "erlang_concept_module_pattern",
      "type": "concept",
      "file_type": "concept",
      "label": "Module Pattern",
      "rationale": "Backend uses thin controller layer delegating to service layer for business logic; validations are schema-only without logic; prompts separated from logic. Frontend mirrors with components organized by concern (ui/layout/flow/features)."
    },
    {
      "id": "erlang_concept_multi_project_monolith",
      "type": "concept",
      "file_type": "concept",
      "label": "Multi-Project Monolith",
      "rationale": "Single Elysia backend serves multiple projects (ERD, PRD) via modular structure. Each project has its own Prisma schema in prisma/projects/ that auto-merges via Prisma 6+ multi-file schema."
    },
    {
      "id": "erlang_concept_dry_kiss_yagni",
      "type": "concept",
      "file_type": "concept",
      "label": "DRY/KISS/YAGNI Principles",
      "rationale": "Both frontend and backend enforce these principles: no copy-paste (DRY), simple code with file size limits (KISS), no speculative abstractions (YAGNI). Backend: functions max 30-50 lines, files max 200 lines. Frontend: components max 100-150 lines, pages max 200 lines, stores max 100 lines."
    },
    {
      "id": "erlang_concept_svelte_flow_state",
      "type": "concept",
      "file_type": "concept",
      "label": "Svelte Flow State Management",
      "rationale": "Uses $state.raw for nodes/edges (not deep reactive) for performance. Undo/redo via snapshot stack. Custom node/edge components in src/lib/components/flow/. Nodes represent tables, edges represent relations."
    },
    {
      "id": "erlang_concept_data_fetching_pattern",
      "type": "concept",
      "file_type": "concept",
      "label": "SvelteKit Data Fetching Pattern",
      "rationale": "Server-side load functions (+page.server.ts) fetch data from backend. Client components receive via $props(). Mutations via form actions or direct API calls. No client-side fetch for data loading (except SSE/real-time)."
    },
    {
      "id": "erlang_concept_ai_key_infrastructure",
      "type": "concept",
      "file_type": "concept",
      "label": "AI API Key Infrastructure",
      "rationale": "Two-tier: server keys (env vars, fallback) and user keys (localStorage only, never persisted to DB). User keys bypass quota. Key rotation via round-robin/random selection across multiple keys per provider."
    },
    {
      "id": "erlang_concept_billing_system",
      "type": "concept",
      "file_type": "concept",
      "label": "Billing & Quota System",
      "rationale": "Three tiers (Free/Pro/Team). Quota tracked per month via Usage table. Payment via Dana transfer + WhatsApp verification (manual flow). Admin verifies payments and updates user plan."
    },
    {
      "id": "erlang_concept_export_formats",
      "type": "concept",
      "file_type": "concept",
      "label": "Export Formats",
      "rationale": "SQL DDL (MySQL/PostgreSQL/SQLite) and Prisma Schema. Generated client-side via Blob download. Includes type mapping per target DB, constraint generation, optional documentation comments and migration files."
    },
    {
      "id": "erlang_concept_auth_flow",
      "type": "concept",
      "file_type": "concept",
      "label": "Authentication Flow",
      "rationale": "Google OAuth only (no email/password). httpOnly JWT cookies. Flow: redirect to Google -> callback -> create/update user -> set JWT cookie -> redirect to dashboard. Admin role auto-assigned via ADMIN_EMAILS env var."
    },
    {
      "id": "erlang_concept_workspace_layout",
      "type": "concept",
      "file_type": "concept",
      "label": "ERD Workspace Layout",
      "rationale": "Full-screen 3-column layout: left AI Chat Panel (collapsible), center Svelte Flow Canvas, right Table Detail Panel (collapsible, appears on node select). Floating toolbar at top with undo/redo/auto-layout/zoom/export."
    },
    {
      "id": "erlang_concept_template_system",
      "type": "concept",
      "file_type": "concept",
      "label": "Template System",
      "rationale": "Pre-built ERD templates (E-commerce, Blog, Inventory, Social Media, School). Public listing, detail view with preview, 'Use Template' creates new project with pre-filled schema."
    },
    {
      "id": "erlang_concept_share_collaboration",
      "type": "concept",
      "file_type": "concept",
      "label": "Share & Collaboration",
      "rationale": "Email-based invites with view/edit roles. Public share links (read-only, no login). Collaborator management (list/remove/change role). Soft-delete projects with 30-day auto-purge trash."
    },
    {
      "id": "erlang_concept_version_history",
      "type": "concept",
      "file_type": "concept",
      "label": "Version History",
      "rationale": "Auto-save snapshots. Max 100 versions per project. Preview per version, diff view for changes, restore to revert. Used for rollback and audit trail."
    },
    {
      "id": "erlang_concept_admin_module",
      "type": "concept",
      "file_type": "concept",
      "label": "Admin Module",
      "rationale": "Protected by adminMiddleware checking role==='admin'. Endpoints for stats, user management, project listing, payment verification/rejection. Admin can manually override user plans. seeder assigns admin role to siamqueen52@gmail.com."
    },
    {
      "id": "erlang_concept_seeding",
      "type": "concept",
      "file_type": "concept",
      "label": "Database Seeding",
      "rationale": "Seed script populates sample ERD templates (5 categories). Admin email auto-assigned admin role via google.service.ts ADMIN_EMAILS constant during OAuth flow."
    }
  ],
